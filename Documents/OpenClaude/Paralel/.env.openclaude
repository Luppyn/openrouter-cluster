# OpenAI-compatible proxy config for openclaude
# Run these before starting openclaude:
#
# Windows (cmd):
#   for /f "tokens=1,2 delims==" %%a in (.env.openclaude) do set %%a=%%b
#
# Windows (powershell):
#   Get-Content .env.openclaude | Where-Object { $_ -notmatch '^\s*#' } | ForEach-Object { Invoke-Expression "$_" }
#
# Bash / WSL:
#   set -a && source .env.openclaude && set +a

OPENAI_BASE_URL=http://localhost:3000/v1
OPENAI_API_KEY=cluster-local
CLAUDE_CODE_USE_OPENAI=1
